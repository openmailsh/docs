{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "OpenMail",
  "seo": {
    "indexing": "navigable",
    "metatags": {
      "og:site_name": "OpenMail Docs",
      "og:type": "website",
      "og:image": "https://openmail.sh/og-image.png",
      "og:image:width": "1200",
      "og:image:height": "630",
      "twitter:card": "summary_large_image",
      "twitter:image": "https://openmail.sh/og-image.png"
    }
  },
  "colors": {
    "primary": "#09090b",
    "light": "#e5e5e5",
    "dark": "#09090b"
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "styling": {
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "dark-plus"
      }
    }
  },
  "favicon": "/favicon.ico",
  "redirects": [
    { "source": "/quickstart/cli", "destination": "/quickstart" },
    { "source": "/quickstart/api", "destination": "/guides/api-integration" },
    { "source": "/guides/cli-quickstart", "destination": "/quickstart" },
    { "source": "/guides/skills/openmail", "destination": "/integrations/skill-files/openmail" },
    { "source": "/guides/skills/references/setup", "destination": "/integrations/skill-files/setup" },
    { "source": "/guides/skills/references/errors", "destination": "/integrations/skill-files/errors" },
    { "source": "/guides/skills/references/api", "destination": "/integrations/skill-files/api" }
  ],
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "pages/welcome",
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Core concepts",
            "pages": [
              "concepts/inboxes",
              "concepts/pods",
              "concepts/custom-domains",
              "concepts/threading",
              "concepts/attachments",
              "concepts/suppressions",
              "concepts/sender-rules",
              "concepts/rate-limits"
            ]
          },
          {
            "group": "WebSockets",
            "pages": [
              "concepts/websockets",
              "guides/websockets/quickstart",
              "pages/websockets/protocol"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "concepts/webhooks",
              "pages/webhooks/events",
              "guides/webhooks",
              "pages/webhooks/verification"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/api-integration",
              "guides/multi-tenancy"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/openclaw",
              "integrations/claude-code",
              "integrations/agent-frameworks"
            ]
          },
          {
            "group": "Best practices",
            "pages": [
              "best-practices/email-deliverability",
              "best-practices/idempotency"
            ]
          },
          {
            "group": "Resources",
            "pages": [
              "pages/resources/faq",
              "pages/resources/support"
            ]
          },
          {
            "group": "Security & privacy",
            "pages": [
              "pages/resources/security/email-protocols"
            ]
          }
        ],
        "icon": "book"
      },
      {
        "tab": "API reference",
        "openapi": "api-reference/openapi.json",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction",
              "api-reference/overview",
              "api-reference/authentication"
            ]
          },
          {
            "group": "Pods",
            "pages": [
              "GET /v1/pods",
              "POST /v1/pods",
              "GET /v1/pods/{id}",
              "PATCH /v1/pods/{id}",
              "DELETE /v1/pods/{id}",
              "POST /v1/pods/{id}/api-keys",
              "GET /v1/pods/{id}/api-keys",
              "DELETE /v1/pods/{id}/api-keys/{keyId}"
            ]
          },
          {
            "group": "Inboxes",
            "pages": [
              "GET /v1/inboxes",
              "POST /v1/inboxes",
              "GET /v1/inboxes/{id}",
              "DELETE /v1/inboxes/{id}"
            ]
          },
          {
            "group": "Messages",
            "pages": [
              "POST /v1/inboxes/{id}/send",
              "GET /v1/inboxes/{id}/messages",
              "GET /v1/inboxes/{id}/threads",
              "PATCH /v1/threads/{id}",
              "GET /v1/threads/{id}/messages"
            ]
          },
          {
            "group": "Attachments",
            "pages": [
              "GET /v1/attachments/{messageId}/{filename}"
            ]
          }
        ],
        "icon": "square-terminal"
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://openmail.sh"
  },
  "navbar": {
    "links": [
      {
        "label": "Pricing",
        "href": "https://openmail.sh/pricing"
      },
      {
        "label": "Status",
        "href": "https://status.openmail.sh"
      },
      {
        "label": "Support",
        "href": "mailto:support@openmail.to"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://console.openmail.sh/login"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity"
    ]
  },
  "footer": {
    "socials": {
      "website": "https://openmail.sh",
      "discord": "https://discord.com/invite/eFfQFMZbsK"
    }
  },
  "integrations": {
    "telemetry": {
      "enabled": true
    }
  },
  "icons": {
    "library": "lucide"
  }
}
