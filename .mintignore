# Mintlify automatically ignores these files and directories:
# .git, .github, .claude, .agents, .idea, node_modules,
# README.md, LICENSE.md, CHANGELOG.md, CONTRIBUTING.md

# Explicitly exclude node_modules (monorepo may resolve from parent)
# Prevents MDX parsing errors from package History.md, SECURITY.md, etc.
node_modules/
**/node_modules/

# Draft content
drafts/
*.draft.mdx

# Project instructions (not docs content)
AGENTS.md
